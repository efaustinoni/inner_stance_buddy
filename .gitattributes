# Ensure shell scripts always use LF line endings regardless of OS
*.sh text eol=lf
.husky/pre-commit text eol=lf
.husky/pre-push text eol=lf

# Source files use LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf
*.toml text eol=lf
